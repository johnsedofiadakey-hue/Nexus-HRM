{
  "name": "personnel-hrm-server",
  "version": "2.0.1",
  "description": "Enterprise Personnel HRM Backend API - Production",
  "main": "src/app.ts",
  "scripts": {
    "dev": "TS_NODE_TRANSPILE_ONLY=true nodemon --exec 'node --max-old-space-size=4096 -r ts-node/register -r dotenv/config' src/app.ts",
    "build": "npx prisma generate && tsc && cp -r src/locales dist/ || mkdir -p dist/locales && cp -r src/locales/* dist/locales/",
    "start": "node --max-old-space-size=4096 dist/app.js",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node src/seed.ts",
    "setup": "ts-node src/scripts/setup.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:fix-leaves": "ts-node src/scripts/fix-leave-balances.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.3",
    "@types/ws": "^8.5.10",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "date-fns": "^3.3.1",
    "dompurify": "^3.3.3",
    "dotenv": "^16.3.1",
    "ecdsa-sig-formatter": "^1.0.11",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.7.0",
    "googleapis": "^171.4.0",
    "helmet": "^7.2.0",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.14.0",
    "prisma": "^5.22.0",
    "sharp": "^0.33.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "xss": "^1.0.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
