# ──────────────────────────────────────────────────────────────────
# Nexus HRM — Server Environment Configuration
# Copy this to .env and fill in your values before running
# ──────────────────────────────────────────────────────────────────

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./prisma/dev.db"
# Production PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexus_hrm?schema=public"

# JWT — REQUIRED, minimum 32 random chars
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_64_CHAR_RANDOM_HEX_STRING"

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS whitelist)
FRONTEND_URL="http://localhost:3000"

# Dev portal master key
DEV_MASTER_KEY="NEXUS-DEV-MASTER-2025-SECURE"

# SMTP (email notifications — optional for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com

# Paystack (payment — optional for dev)
PAYSTACK_PUBLIC_KEY=pk_test_xxxx
PAYSTACK_SECRET_KEY=sk_test_xxxx
