# ─────────────────────────────────────────────────────────────────────────────
# NEXUS HRM — Production Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────────────────
# PostgreSQL (Render / Supabase / Neon / Railway / etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexus_hrm?schema=public"

# ── JWT AUTH ──────────────────────────────────────────────────────────────────
# REQUIRED — minimum 64 random hex chars
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_128_CHAR_RANDOM_HEX_STRING"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_ANOTHER_128_CHAR_RANDOM_HEX_STRING"

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (no trailing slash)
FRONTEND_URL="https://your-app-name.onrender.com"

# Production data-safety controls
# Destructive HTTP operations are always blocked in production. This flag is
# only honored in non-production environments for intentional test resets.
ALLOW_DESTRUCTIVE_OPERATIONS="false"
RUN_STARTUP_TARGET_SYNC="false"
REQUIRE_CLOUD_BACKUP="true"
# Store the JSON credential in the hosting provider's secret manager.
GOOGLE_DRIVE_KEY_JSON=""
# Required only for an explicitly enabled non-production destructive reset.
DESTRUCTIVE_OPERATION_PIN=""

# ── DEV PORTAL ────────────────────────────────────────────────────────────────
DEV_MASTER_KEY="CHANGE_THIS_TO_A_SEPARATE_RANDOM_ADMIN_SECRET"

# ── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
# Required for welcome emails, leave notifications, payslips
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com

# ── PAYSTACK (payments) ───────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_live_xxxx
PAYSTACK_SECRET_KEY=sk_live_xxxx

# ── GOOGLE DRIVE 2TB BACKUP SYNC ──────────────────────────────────────────────
# Path to your Service Account JSON (Recommend: server/google-drive-key.json)
GOOGLE_DRIVE_KEY_PATH=server/google-drive-key.json
# Folder ID will be automatically generated and saved to DB on first run
GOOGLE_DRIVE_FOLDER_ID=
