generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KpiSheet {
  id                 String    @id @default(uuid())
  organizationId     String?   @default("default-tenant")
  month              Int
  year               Int
  lockedAt           DateTime?
  title              String
  employeeId         String?
  reviewerId         String?
  totalScore         Decimal?
  status             String?   @default("DRAFT")
  isLocked           Boolean   @default(false)
  createdAt          DateTime  @default(now())
  isTemplate         Boolean   @default(false)
  targetDepartmentId Int?
  items              KpiItem[]
  employee           User?     @relation("EmployeeKPIs", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer           User?     @relation("ReviewerKPIs", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId])
  @@index([organizationId, reviewerId])
  @@index([organizationId, targetDepartmentId])
  @@index([organizationId, month, year])
}

model KpiItem {
  id             String      @id @default(uuid())
  organizationId String?     @default("default-tenant")
  targetValue    Decimal
  weight         Decimal     @default(1.0)
  actualValue    Decimal     @default(0)
  sheetId        String
  name           String
  category       String      @default("General")
  description    String      @default("")
  score          Decimal?
  createdAt      DateTime    @default(now())
  lastEntryDate  DateTime?
  endDate        DateTime?
  frequency      String      @default("MONTHLY")
  metricType     String      @default("NUMERIC")
  startDate      DateTime?
  sheet          KpiSheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  updates        KpiUpdate[]

  @@index([organizationId, sheetId])
}

model Target {
  id                 String                  @id @default(uuid())
  organizationId     String?                 @default("default-tenant")
  title              String
  description        String?
  level              String                  @default("INDIVIDUAL")
  type               String                  @default("SINGLE")
  status             String                  @default("DRAFT")
  dueDate            DateTime?
  weight             Decimal                 @default(1.0)
  parentTargetId     String?
  departmentId       Int?
  assigneeId         String?
  originatorId       String
  lineManagerId      String?
  reviewerId         String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  contributionWeight Decimal                 @default(0)
  progress           Decimal                 @default(0)
  archivedAt         DateTime?
  isArchived         Boolean                 @default(false)
  assignee           User?                   @relation("TargetAssignee", fields: [assigneeId], references: [id])
  department         Department?             @relation(fields: [departmentId], references: [id])
  lineManager        User?                   @relation("TargetLineManager", fields: [lineManagerId], references: [id])
  originator         User                    @relation("TargetOriginator", fields: [originatorId], references: [id])
  parentTarget       Target?                 @relation("TargetHierarchy", fields: [parentTargetId], references: [id], onDelete: Cascade)
  childTargets       Target[]                @relation("TargetHierarchy")
  reviewer           User?                   @relation("TargetReviewer", fields: [reviewerId], references: [id])
  acknowledgments    TargetAcknowledgement[]
  metrics            TargetMetric[]
  updates            TargetUpdate[]

  @@index([organizationId, assigneeId])
  @@index([organizationId, departmentId])
  @@index([organizationId, status])
}

model TargetMetric {
  id                String         @id @default(uuid())
  organizationId    String?        @default("default-tenant")
  targetId          String
  title             String
  description       String?
  metricType        String         @default("NUMERICAL")
  targetValue       Decimal?
  currentValue      Decimal        @default(0)
  unit              String?
  currency          String?        @default("GNF")
  weight            Decimal        @default(1.0)
  qualitativePrompt String?
  target            Target         @relation(fields: [targetId], references: [id], onDelete: Cascade)
  updates           TargetUpdate[]

  @@index([organizationId, targetId])
}

model TargetAcknowledgement {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  targetId       String
  userId         String
  status         String   @default("ACKNOWLEDGED")
  message        String?
  createdAt      DateTime @default(now())
  target         Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, targetId])
}

model TargetUpdate {
  id             String        @id @default(uuid())
  organizationId String?       @default("default-tenant")
  targetId       String
  metricId       String?
  submittedById  String
  value          Decimal?
  comment        String?
  attachmentUrl  String?
  createdAt      DateTime      @default(now())
  metric         TargetMetric? @relation(fields: [metricId], references: [id], onDelete: Cascade)
  submittedBy    User          @relation(fields: [submittedById], references: [id])
  target         Target        @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([organizationId, targetId])
}

model Asset {
  id                String            @id @default(uuid())
  organizationId    String?           @default("default-tenant")
  name              String
  description       String?
  isCompanyProperty Boolean           @default(true)
  serialNumber      String            @unique
  make              String?
  model             String?
  type              String
  status            String            @default("AVAILABLE")
  purchaseDate      DateTime?
  warrantyExpiry    DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  assignments       AssetAssignment[]
  assetReturns      AssetReturn[]

  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  userId         String?
  action         String?
  entity         String?
  entityId       String?
  details        String?
  ipAddress      String?
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}

model EmployeeHistory {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String?
  createdById    String?
  title          String?
  description    String?
  change         String?
  type           String?
  severity       String?
  status         String?  @default("OPEN")
  loggedById     String?
  createdAt      DateTime @default(now())
  createdBy      User?    @relation("CreatedHistory", fields: [createdById], references: [id], onDelete: Cascade)
  employee       User?    @relation("EmployeeHistory", fields: [employeeId], references: [id], onDelete: Cascade)
  loggedBy       User?    @relation("LoggedByHistory", fields: [loggedById], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId])
}

model ApiUsage {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  path           String
  method         String
  statusCode     Int
  duration       Int
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([path, createdAt])
}

model AssetAssignment {
  id                String    @id @default(uuid())
  organizationId    String?   @default("default-tenant")
  returnedAt        DateTime?
  details           String?
  status            String?   @default("OPEN")
  conditionOnAssign String?
  conditionOnReturn String?
  loggedById        String?
  userId            String?
  assetId           String?
  assignedAt        DateTime  @default(now())
  asset             Asset?    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  loggedBy          User?     @relation("LoggedByAssignments", fields: [loggedById], references: [id], onDelete: Cascade)
  user              User?     @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

model User {
  id                      String                  @id @default(uuid())
  email                   String                  @unique
  passwordHash            String
  fullName                String
  role                    String                  @default("STAFF")
  employeeCode            String?
  status                  String                  @default("ACTIVE")
  position                String?
  departmentId            Int?
  jobTitle                String
  joinDate                DateTime?
  employmentType          String?
  dob                     DateTime?
  gender                  String?
  nationalId              String?
  contactNumber           String?
  address                 String?
  profilePhoto            String?
  nextOfKinName           String?
  nextOfKinRelation       String?
  nextOfKinContact        String?
  avatarUrl               String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  salary                  Decimal?
  currency                String                  @default("GNF")
  bankName                String?
  bankAccountNumber       String?
  bankBranch              String?
  ssnitNumber             String?
  bankAccountEnc          String?
  ghanaCardEnc            String?
  ssnitEnc                String?
  salaryEnc               String?
  nationalIdDocUrl        String?
  leaveBalance            Decimal?                @default(30)
  leaveAllowance          Decimal?                @default(30)
  hasManualLeaveOverride  Boolean                 @default(false)
  lastManualLeaveAdjustmentAt DateTime?
  leaveAccruedAt          DateTime?
  supervisorId            String?
  isArchived              Boolean                 @default(false)
  archivedDate            DateTime?
  organizationId          String?                 @default("default-tenant")
  subUnitId               String?
  education               String?
  bloodGroup              String?
  certifications          String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  maritalStatus           String?
  biometricId             String?
  countryOfOrigin         String?
  nationality             String?
  signatureUrl            String?
  createdAnnouncements    Announcement[]          @relation("CreatedAnnouncements")
  appraisalPackets        AppraisalPacket[]       @relation("EmployeeAppraisalPackets")
  resolvedAppraisals      AppraisalPacket[]       @relation("ResolvedAppraisals")
  appraisalReviewsByMe    AppraisalReview[]       @relation("ReviewerAppraisalReviews")
  loggedByAssignments     AssetAssignment[]       @relation("LoggedByAssignments")
  userAssignments         AssetAssignment[]       @relation("UserAssignments")
  attendanceLogs          AttendanceLog[]         @relation("EmployeeAttendance")
  auditLogs               AuditLog[]
  compensationHistory     CompensationHistory[]   @relation("EmployeeCompensation")
  managesDepartment       Department[]            @relation("DepartmentManager")
  documents               EmployeeDocument[]      @relation("EmployeeDocuments")
  createdHistory          EmployeeHistory[]       @relation("CreatedHistory")
  historyLogs             EmployeeHistory[]       @relation("EmployeeHistory")
  loggedByHistory         EmployeeHistory[]       @relation("LoggedByHistory")
  queriesReceived         EmployeeQuery[]         @relation("QueryRecipient")
  queriesIssued           EmployeeQuery[]         @relation("QueryIssuer")
  employeeReportingLines  EmployeeReporting[]     @relation("EmployeeReportingLines")
  managedReportingLines   EmployeeReporting[]     @relation("ManagerReportingLines")
  interviewsConducted     ExitInterview[]         @relation("ExitInterviewer")
  approvedExpenses        ExpenseClaim[]          @relation("ApprovedExpenses")
  expenses                ExpenseClaim[]          @relation("EmployeeExpenses")
  handoverWorkAccepted    HandoverRecord[]        @relation("HandoverReliever")
  handoverRequestsSent    HandoverRecord[]        @relation("HandoverRequester")
  interviewFeedbackByMe   InterviewFeedback[]     @relation("ReviewerFeedback")
  assignedInterviewStages InterviewStage[]        @relation("InterviewerStage")
  kpiSheets               KpiSheet[]              @relation("EmployeeKPIs")
  kpiReviews              KpiSheet[]              @relation("ReviewerKPIs")
  leaves                  LeaveRequest[]          @relation("EmployeeLeaves")
  hrReviewLeaves          LeaveRequest[]          @relation("HRReviewLeaves")
  managerLeaves           LeaveRequest[]          @relation("ManagerLeaves")
  reliefRequests          LeaveRequest[]          @relation("RelieverLeaves")
  approvedLoans           Loan[]                  @relation("ApprovedLoans")
  loans                   Loan[]                  @relation("EmployeeLoans")
  notifications           Notification[]          @relation("UserNotifications")
  employeeOffboarding     OffboardingProcess[]    @relation("EmployeeOffboarding")
  onboardingSessions      OnboardingSession[]     @relation("EmployeeOnboarding")
  resetTokens             PasswordResetToken[]    @relation("UserResetTokens")
  payrollItems            PayrollItem[]           @relation("EmployeePayroll")
  RefreshToken            RefreshToken[]
  saasSubscriptions       SaasSubscription[]      @relation("ClientSaasSubscription")
  managesSubUnits         SubUnit[]               @relation("SubUnitManager")
  subscriptions           Subscription[]          @relation("ClientSubscription")
  assignedTickets         SupportTicket[]         @relation("AssignedTickets")
  employeeTickets         SupportTicket[]         @relation("EmployeeTickets")
  targetsAssignedToMe     Target[]                @relation("TargetAssignee")
  targetsManagedByMe      Target[]                @relation("TargetLineManager")
  targetsByMe             Target[]                @relation("TargetOriginator")
  targetsReviewedByMe     Target[]                @relation("TargetReviewer")
  targetAcknowledgements  TargetAcknowledgement[]
  targetUpdates           TargetUpdate[]
  ticketComments          TicketComment[]
  trainingEnrollments     TrainingEnrollment[]    @relation("EmployeeTraining")
  departmentObj           Department?             @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  organization            Organization?           @relation(fields: [organizationId], references: [id])
  subUnit                 SubUnit?                @relation("SubUnitEmployees", fields: [subUnitId], references: [id])
  supervisor              User?                   @relation("Hierarchy", fields: [supervisorId], references: [id])
  subordinates            User[]                  @relation("Hierarchy")

  @@unique([employeeCode, organizationId])
  @@index([role, status])
  @@index([departmentId, isArchived, status])
  @@index([supervisorId])
  @@index([organizationId])
  @@index([jobTitle])
  @@index([fullName])
}

model CompensationHistory {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String
  type           String
  previousSalary Decimal
  newSalary      Decimal
  currency       String   @default("GNF")
  reason         String?
  effectiveDate  DateTime
  authorizedById String?
  createdAt      DateTime @default(now())
  employee       User     @relation("EmployeeCompensation", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId])
}

model PasswordResetToken {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  userId         String
  token          String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation("UserResetTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

model EmployeeDocument {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String
  title          String
  category       String
  fileUrl        String
  uploadedAt     DateTime @default(now())
  employee       User     @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId])
}

model EmployeeQuery {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String
  issuedById     String
  subject        String
  description    String
  status         String   @default("OPEN")
  resolution     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       User     @relation("QueryRecipient", fields: [employeeId], references: [id], onDelete: Cascade)
  issuedBy       User     @relation("QueryIssuer", fields: [issuedById], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId])
}

model Department {
  id             Int             @id @default(autoincrement())
  organizationId String?         @default("default-tenant")
  name           String          @unique
  managerId      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  announcements  Announcement[]
  manager        User?           @relation("DepartmentManager", fields: [managerId], references: [id])
  kpis           DepartmentKPI[]
  jobPositions   JobPosition[]
  subUnits       SubUnit[]
  targets        Target[]
  employees      User[]          @relation("DepartmentEmployees")

  @@index([organizationId])
}

model SubUnit {
  id             String     @id @default(uuid())
  organizationId String?    @default("default-tenant")
  name           String
  departmentId   Int
  managerId      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  manager        User?      @relation("SubUnitManager", fields: [managerId], references: [id])
  employees      User[]     @relation("SubUnitEmployees")

  @@unique([name, departmentId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([managerId])
}

model LeaveRequest {
  id                         String           @id @default(uuid())
  organizationId             String?          @default("default-tenant")
  employeeId                 String
  startDate                  DateTime
  endDate                    DateTime
  leaveDays                  Decimal          @default(0)
  reason                     String
  relieverId                 String?
  status                     String           @default("DRAFT")
  managerComment             String?
  createdAt                  DateTime         @default(now())
  hrComment                  String?
  hrReviewerId               String?
  managerId                  String?
  relieverComment            String?
  relieverRespondedAt        DateTime?
  relieverStatus             String           @default("PENDING")
  updatedAt                  DateTime         @updatedAt
  leaveType                  String           @default("Annual")
  handoverAcknowledged       Boolean          @default(false)
  handoverNotes              String?
  archivedAt                 DateTime?
  isArchived                 Boolean          @default(false)
  relieverAcceptanceRequired Boolean          @default(false)
  handoverRecords            HandoverRecord[]
  employee                   User             @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)
  hrReviewer                 User?            @relation("HRReviewLeaves", fields: [hrReviewerId], references: [id])
  manager                    User?            @relation("ManagerLeaves", fields: [managerId], references: [id])
  reliever                   User?            @relation("RelieverLeaves", fields: [relieverId], references: [id])

  @@index([organizationId, employeeId, status])
  @@index([organizationId, relieverId, status])
}

model HandoverRecord {
  id             String       @id @default(uuid())
  organizationId String?      @default("default-tenant")
  leaveRequestId String
  requesterId    String
  relieverId     String
  handoverNotes  String?
  acceptedAt     DateTime     @default(now())
  status         String       @default("ACCEPTED")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  reliever       User         @relation("HandoverReliever", fields: [relieverId], references: [id])
  requester      User         @relation("HandoverRequester", fields: [requesterId], references: [id])

  @@index([organizationId, leaveRequestId])
  @@index([relieverId, organizationId, status])
}

model Cycle {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  name           String
  type           String
  startDate      DateTime
  endDate        DateTime
  status         String   @default("DRAFT")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model ReviewCycle {
  id             String                @id @default(uuid())
  organizationId String
  title          String
  startDate      DateTime
  endDate        DateTime
  status         String                @default("ACTIVE")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  reviews        PerformanceReviewV2[]
}

model Announcement {
  id             String      @id @default(uuid())
  organizationId String?     @default("default-tenant")
  title          String
  content        String
  createdById    String
  targetAudience String
  departmentId   Int?
  publishDate    DateTime    @default(now())
  expirationDate DateTime?
  priority       String      @default("NORMAL")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdBy      User        @relation("CreatedAnnouncements", fields: [createdById], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id])

  @@index([organizationId, targetAudience, expirationDate])
}

model AppraisalCycle {
  id             String            @id @default(uuid())
  organizationId String?           @default("default-tenant")
  title          String
  period         String
  startDate      DateTime
  endDate        DateTime
  status         String            @default("DRAFT")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  packets        AppraisalPacket[]

  @@index([organizationId, status])
}

model AppraisalPacket {
  id                 String            @id @default(uuid())
  organizationId     String?           @default("default-tenant")
  cycleId            String
  employeeId         String
  currentStage       String            @default("SELF_REVIEW")
  status             String            @default("OPEN")
  supervisorId       String?
  managerId          String?
  hrReviewerId       String?
  finalReviewerId    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  matrixSupervisorId String?
  disputeReason      String?
  disputeResolution  String?
  disputeResolvedAt  DateTime?
  gapDetected        Boolean           @default(false)
  isDisputed         Boolean           @default(false)
  resolvedById       String?
  finalScore         Decimal?
  finalVerdict       String?
  arbitrationLogic   String?
  cycle              AppraisalCycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee           User              @relation("EmployeeAppraisalPackets", fields: [employeeId], references: [id], onDelete: Cascade)
  resolvedBy         User?             @relation("ResolvedAppraisals", fields: [resolvedById], references: [id])
  reviews            AppraisalReview[]

  @@unique([cycleId, employeeId])
  @@index([organizationId, employeeId])
  @@index([organizationId, currentStage])
}

model AppraisalReview {
  id               String          @id @default(uuid())
  organizationId   String?         @default("default-tenant")
  packetId         String
  reviewerId       String
  reviewStage      String
  status           String          @default("PENDING")
  submittedAt      DateTime?
  overallRating    Decimal?
  summary          String?
  strengths        String?
  weaknesses       String?
  achievements     String?
  developmentNeeds String?
  responses        String?         @default("{}")
  packet           AppraisalPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  reviewer         User            @relation("ReviewerAppraisalReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([packetId, reviewStage])
  @@index([organizationId, packetId])
  @@index([reviewerId])
}

model Organization {
  id                     String               @id @default(uuid())
  name                   String
  logoUrl                String?
  email                  String?
  phone                  String?
  address                String?
  city                   String?
  country                String?
  currency               String               @default("GNF")
  subscriptionPlan       String               @default("FREE")
  subscriptionAmount     Decimal              @default(0)
  billingStatus          String               @default("FREE")
  isSuspended            Boolean              @default(false)
  nextBillingDate        DateTime?
  primaryColor           String               @default("#4F46E5")
  secondaryColor         String               @default("#1E293B")
  accentColor            String               @default("#F59E0B")
  textColor              String               @default("#FFFFFF")
  sidebarColor           String               @default("#080c16")
  subtitle               String               @default("HRM OS")
  themePreset            String               @default("nexus-dark")
  lightMode              Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  customDomain           String?              @unique
  discountFixed          Decimal?             @default(0)
  discountPercentage     Decimal?             @default(0)
  features               String               @default("{}")
  isEnterprise           Boolean              @default(false)
  trialEndsAt            DateTime?
  trialStartDate         DateTime             @default(now())
  language               String               @default("en")
  bgCard                 String?              @default("#ffffff")
  bgMain                 String?              @default("#f8fafc")
  sidebarActive          String?              @default("#1e293b")
  sidebarBg              String?              @default("#080c16")
  sidebarText            String?              @default("#ffffff")
  textMuted              String?              @default("#94a3b8")
  textPrimary            String?              @default("#0f172a")
  textSecondary          String?              @default("#475569")
  isAiEnabled            Boolean              @default(false)
  bgElevated             String?              @default("#f1f5f9")
  bgInput                String?              @default("#ffffff")
  borderSubtle           String?              @default("#e2e8f0")
  textInverse            String?              @default("#ffffff")
  errorColor             String?              @default("#ef4444")
  infoColor              String?              @default("#06b6d4")
  successColor           String?              @default("#10b981")
  warningColor           String?              @default("#f59e0b")
  defaultLeaveAllowance  Decimal              @default(30)
  allowLeaveBorrowing    Boolean              @default(false)
  allowLeaveCarryForward Boolean              @default(true)
  borrowingLimit         Decimal              @default(5)
  carryForwardLimit      Decimal              @default(10)
  securityEvents         LoginSecurityEvent[]
  settings               SystemSettings?
  users                  User[]
}

model SystemSettings {
  id                      String        @id @default(uuid())
  organizationId          String?       @unique
  isMaintenanceMode       Boolean       @default(false)
  securityLockdown        Boolean       @default(false)
  smtpHost                String?
  smtpPort                Int?
  smtpUser                String?
  smtpPass                String?
  smtpFrom                String?
  paystackPublicKey       String?
  paystackSecretKey       String?
  monthlyPriceGHS         Decimal?
  annualPriceGHS          Decimal?
  trialDays               Int           @default(14)
  loginNotice             String?
  loginSubtitle           String?
  loginBullets            String?
  updatedAt               DateTime      @updatedAt
  backupFrequencyDays     Int           @default(7)
  maintenanceNotice       String?
  paystackPayLink         String?
  securityLockdownMessage String?
  annualPrice             Decimal?
  currency                String        @default("GNF")
  monthlyPrice            Decimal?
  googleDriveFolderId     String?
  domainExpiryDate        DateTime?
  databaseExpiryDate      DateTime?
  organization            Organization? @relation(fields: [organizationId], references: [id])
}

model Notification {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  userId         String
  title          String
  message        String
  type           String   @default("INFO")
  link           String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  user           User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, isRead])
}

model PayrollRun {
  id             String        @id @default(uuid())
  organizationId String?       @default("default-tenant")
  period         String
  month          Int
  year           Int
  status         String        @default("DRAFT")
  totalGross     Decimal       @default(0)
  totalNet       Decimal       @default(0)
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          PayrollItem[]

  @@index([organizationId, year, month, status])
  @@index([period, status])
}

model PayrollItem {
  id              String     @id @default(uuid())
  organizationId  String?    @default("default-tenant")
  runId           String
  employeeId      String
  baseSalary      Decimal
  currency        String     @default("GNF")
  overtime        Decimal    @default(0)
  bonus           Decimal    @default(0)
  allowances      Decimal    @default(0)
  tax             Decimal    @default(0)
  ssnit           Decimal    @default(0)
  otherDeductions Decimal    @default(0)
  grossPay        Decimal
  netPay          Decimal
  notes           String?
  createdAt       DateTime   @default(now())
  employee        User       @relation("EmployeePayroll", fields: [employeeId], references: [id], onDelete: Cascade)
  run             PayrollRun @relation(fields: [runId], references: [id])

  @@unique([runId, employeeId])
  @@index([organizationId])
}

model OnboardingTemplate {
  id             String              @id @default(uuid())
  organizationId String?             @default("default-tenant")
  name           String
  description    String?
  isDefault      Boolean             @default(false)
  createdAt      DateTime            @default(now())
  sessions       OnboardingSession[]
  tasks          OnboardingTask[]

  @@index([organizationId])
}

model OnboardingTask {
  id             String             @id @default(uuid())
  organizationId String?            @default("default-tenant")
  templateId     String
  title          String
  description    String?
  category       String             @default("General")
  dueAfterDays   Int                @default(1)
  isRequired     Boolean            @default(true)
  order          Int                @default(0)
  template       OnboardingTemplate @relation(fields: [templateId], references: [id])

  @@index([organizationId, templateId])
}

model OnboardingSession {
  id             String             @id @default(uuid())
  organizationId String?            @default("default-tenant")
  employeeId     String
  templateId     String
  startDate      DateTime           @default(now())
  completedAt    DateTime?
  progress       Int                @default(0)
  createdAt      DateTime           @default(now())
  items          OnboardingItem[]
  employee       User               @relation("EmployeeOnboarding", fields: [employeeId], references: [id], onDelete: Cascade)
  template       OnboardingTemplate @relation(fields: [templateId], references: [id])

  @@index([organizationId, employeeId])
}

model OnboardingItem {
  id             String            @id @default(uuid())
  organizationId String?           @default("default-tenant")
  sessionId      String
  taskId         String
  title          String
  category       String
  dueDate        DateTime?
  completedAt    DateTime?
  completedBy    String?
  notes          String?
  isRequired     Boolean           @default(true)
  session        OnboardingSession @relation(fields: [sessionId], references: [id])

  @@index([organizationId, sessionId])
}

model TrainingProgram {
  id             String               @id @default(uuid())
  organizationId String?              @default("default-tenant")
  title          String
  description    String?
  provider       String?
  startDate      DateTime?
  endDate        DateTime?
  durationHours  Int?
  cost           Decimal?
  maxSeats       Int?
  status         String               @default("PLANNED")
  createdById    String?
  createdAt      DateTime             @default(now())
  enrollments    TrainingEnrollment[]

  @@index([organizationId, status])
  @@index([organizationId])
}

model TrainingEnrollment {
  id             String          @id @default(uuid())
  organizationId String?         @default("default-tenant")
  programId      String
  employeeId     String
  enrolledAt     DateTime        @default(now())
  completedAt    DateTime?
  score          Decimal?
  certificate    String?
  status         String          @default("ENROLLED")
  employee       User            @relation("EmployeeTraining", fields: [employeeId], references: [id], onDelete: Cascade)
  program        TrainingProgram @relation(fields: [programId], references: [id])

  @@unique([programId, employeeId])
  @@index([organizationId, employeeId])
}

model PublicHoliday {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  name           String
  date           DateTime
  country        String   @default("GH")
  isRecurring    Boolean  @default(true)
  year           Int?
  createdAt      DateTime @default(now())

  @@index([organizationId, country, date])
}

model Subscription {
  id                 String    @id @default(uuid())
  organizationId     String?   @default("default-tenant")
  clientId           String
  plan               String    @default("MONTHLY")
  priceGHS           Decimal?
  status             String    @default("TRIAL")
  orgName            String?
  contactEmail       String?
  paystackRef        String?
  paystackSubCode    String?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  currency           String    @default("GNF")
  price              Decimal?
  client             User      @relation("ClientSubscription", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Loan {
  id                String            @id @default(uuid())
  organizationId    String?           @default("default-tenant")
  employeeId        String
  type              String            @default("ADVANCE")
  principalAmount   Decimal
  interestRate      Decimal           @default(0)
  totalRepayment    Decimal
  installmentAmount Decimal
  monthsDuration    Int
  purpose           String?
  status            String            @default("PENDING")
  requestedAt       DateTime          @default(now())
  approvedAt        DateTime?
  approvedById      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  approver          User?             @relation("ApprovedLoans", fields: [approvedById], references: [id])
  employee          User              @relation("EmployeeLoans", fields: [employeeId], references: [id], onDelete: Cascade)
  installments      LoanInstallment[]

  @@index([organizationId, employeeId])
}

model LoanInstallment {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  loanId         String
  amount         Decimal
  deductedRunId  String?
  month          Int
  year           Int
  status         String    @default("PENDING")
  paidAt         DateTime?
  loan           Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([organizationId, loanId])
}

model ExpenseClaim {
  id              String    @id @default(uuid())
  organizationId  String?   @default("default-tenant")
  employeeId      String
  title           String
  description     String?
  amount          Decimal
  currency        String    @default("GNF")
  category        String
  receiptUrl      String?
  status          String    @default("PENDING")
  submittedAt     DateTime  @default(now())
  approvedAt      DateTime?
  approvedById    String?
  paidInRunId     String?
  rejectionReason String?
  approver        User?     @relation("ApprovedExpenses", fields: [approvedById], references: [id])
  employee        User      @relation("EmployeeExpenses", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId, status])
}

model AttendanceLog {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  employeeId     String
  date           DateTime
  clockIn        DateTime?
  clockOut       DateTime?
  status         String    @default("PRESENT")
  notes          String?
  locationIn     String?
  locationOut    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  source         String    @default("WEB")
  employee       User      @relation("EmployeeAttendance", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId, date, status])
  @@index([employeeId, clockIn, clockOut])
}

model SaasSubscription {
  id              String    @id @default(uuid())
  organizationId  String?   @default("default-tenant")
  clientId        String
  plan            String    @default("MONTHLY")
  status          String    @default("ACTIVE")
  amount          Decimal   @default(50.00)
  nextBillingDate DateTime
  lastPaymentDate DateTime?
  paystackRef     String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  client          User      @relation("ClientSaasSubscription", fields: [clientId], references: [id])

  @@index([organizationId])
}

model BackupLog {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  filename       String
  sizeBytes      Int
  status         String   @default("SUCCESS")
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  tokenHash      String    @unique
  ipAddress      String?
  userAgent      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([expiresAt])
}

model LoginSecurityEvent {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  ipAddress      String?
  userAgent      String?
  success        Boolean      @default(false)
  reason         String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, email, createdAt])
  @@index([ipAddress, createdAt])
}

model DepartmentKPI {
  id                String       @id @default(uuid())
  organizationId    String
  departmentId      Int
  title             String
  description       String?
  metricType        String
  targetValue       Decimal
  measurementPeriod String
  assignedById      String
  assignedToId      String?
  status            String       @default("ACTIVE")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  department        Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  teamTargets       TeamTarget[]

  @@index([organizationId, departmentId, measurementPeriod])
  @@index([organizationId, assignedToId])
  @@index([assignedById])
}

model TeamTarget {
  id                String           @id @default(uuid())
  organizationId    String
  departmentKpiId   String
  managerId         String
  teamName          String?
  title             String
  description       String?
  metricType        String
  targetValue       Decimal
  measurementPeriod String
  status            String           @default("ACTIVE")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  originKPIId       String?
  employeeTargets   EmployeeTarget[]
  departmentKpi     DepartmentKPI    @relation(fields: [departmentKpiId], references: [id], onDelete: Cascade)

  @@index([organizationId, departmentKpiId])
  @@index([organizationId, managerId, measurementPeriod])
}

model EmployeeTarget {
  id                String     @id @default(uuid())
  organizationId    String
  teamTargetId      String
  employeeId        String
  title             String
  description       String?
  metricType        String
  targetValue       Decimal
  measurementPeriod String
  assignedById      String
  assignedToId      String
  status            String     @default("ACTIVE")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  managerId         String?
  originKPIId       String?
  teamTarget        TeamTarget @relation(fields: [teamTargetId], references: [id], onDelete: Cascade)

  @@index([organizationId, employeeId, measurementPeriod])
  @@index([organizationId, teamTargetId])
  @@index([assignedById])
}

model PerformanceReviewV2 {
  id             String             @id @default(uuid())
  organizationId String
  employeeId     String
  managerId      String?
  directorId     String?
  cycle          String
  selfReview     String?
  managerReview  String?
  directorReview String?
  selfScore      Decimal?
  managerScore   Decimal?
  directorScore  Decimal?
  finalScore     Decimal?
  cycleId        String
  status         String             @default("DRAFT")
  submittedAt    DateTime?
  validatedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  cycleObj       ReviewCycle        @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  scores         PerformanceScore[]

  @@index([organizationId, employeeId, cycleId])
  @@index([organizationId, status])
  @@index([managerId, directorId])
}

model PerformanceScore {
  id                  String              @id @default(uuid())
  organizationId      String
  performanceReviewId String
  kpiTitle            String
  metricType          String
  targetValue         Decimal?
  achievedValue       Decimal?
  weightedScore       Decimal?
  notes               String?
  createdAt           DateTime            @default(now())
  review              PerformanceReviewV2 @relation(fields: [performanceReviewId], references: [id], onDelete: Cascade)

  @@index([organizationId, performanceReviewId])
}

model JobPosition {
  id             String      @id @default(uuid())
  organizationId String
  title          String
  departmentId   Int?
  description    String?
  location       String?
  employmentType String?
  status         String      @default("OPEN")
  openedById     String?
  closedAt       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  candidates     Candidate[] @relation("JobCandidates")
  department     Department? @relation(fields: [departmentId], references: [id])

  @@index([organizationId, status, createdAt])
}

model Candidate {
  id                String              @id @default(uuid())
  organizationId    String
  jobPositionId     String
  fullName          String
  email             String?
  phone             String?
  resumeUrl         String?
  source            String?
  status            String              @default("APPLIED")
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  jobPosition       JobPosition         @relation("JobCandidates", fields: [jobPositionId], references: [id], onDelete: Cascade)
  interviewFeedback InterviewFeedback[]
  interviewStages   InterviewStage[]
  offerLetter       OfferLetter?

  @@index([organizationId, jobPositionId, status])
  @@index([email, phone])
}

model InterviewStage {
  id             String              @id @default(uuid())
  organizationId String
  candidateId    String
  stage          String
  scheduledAt    DateTime?
  interviewerId  String?
  outcome        String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  status         String              @default("APPLIED")
  feedback       InterviewFeedback[]
  candidate      Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewer    User?               @relation("InterviewerStage", fields: [interviewerId], references: [id])

  @@index([organizationId, candidateId, stage])
}

model InterviewFeedback {
  id               String          @id @default(uuid())
  organizationId   String
  candidateId      String
  interviewStageId String?
  reviewerId       String
  rating           Decimal?
  feedback         String?
  recommendation   String?
  createdAt        DateTime        @default(now())
  candidate        Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewStage   InterviewStage? @relation(fields: [interviewStageId], references: [id])
  reviewer         User            @relation("ReviewerFeedback", fields: [reviewerId], references: [id])

  @@index([organizationId, candidateId])
  @@index([organizationId, reviewerId])
  @@index([interviewStageId])
}

model OfferLetter {
  id             String    @id @default(uuid())
  organizationId String
  candidateId    String    @unique
  fileUrl        String?
  salaryOffered  Decimal?
  currency       String?   @default("GNF")
  status         String    @default("DRAFT")
  sentAt         DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  candidate      Candidate @relation(fields: [candidateId], references: [id])

  @@index([organizationId, candidateId, status])
}

model OnboardingChecklist {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  source         String?   @default("ATS")
  status         String    @default("IN_PROGRESS")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, employeeId, status])
}

model OnboardingChecklistTask {
  id             String    @id @default(uuid())
  organizationId String
  checklistId    String
  title          String
  description    String?
  category       String?   @default("GENERAL")
  status         String    @default("PENDING")
  dueDate        DateTime?
  completedAt    DateTime?
  completedById  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, checklistId, status])
}

model OffboardingProcess {
  id                String               @id @default(uuid())
  organizationId    String
  employeeId        String
  triggeredById     String
  status            String               @default("INITIATED")
  effectiveDate     DateTime?
  accountDisabledAt DateTime?
  finalPayrollRunId String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  templateId        String?
  assetReturns      AssetReturn[]
  exitInterviews    ExitInterview[]
  items             OffboardingItem[]
  employee          User                 @relation("EmployeeOffboarding", fields: [employeeId], references: [id])
  template          OffboardingTemplate? @relation(fields: [templateId], references: [id])

  @@index([organizationId, employeeId, status])
}

model ExitInterview {
  id             String             @id @default(uuid())
  organizationId String
  offboardingId  String
  interviewerId  String?
  interviewDate  DateTime?
  reason         String?
  feedback       String?
  rehireEligible Boolean?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  interviewer    User?              @relation("ExitInterviewer", fields: [interviewerId], references: [id])
  offboarding    OffboardingProcess @relation(fields: [offboardingId], references: [id])

  @@index([organizationId, offboardingId])
}

model AssetReturn {
  id             String             @id @default(uuid())
  organizationId String
  offboardingId  String
  assetId        String?
  assetName      String?
  returned       Boolean            @default(false)
  returnedAt     DateTime?
  conditionNotes String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  asset          Asset?             @relation(fields: [assetId], references: [id])
  offboarding    OffboardingProcess @relation(fields: [offboardingId], references: [id])

  @@index([organizationId, offboardingId, returned])
}

model OffboardingTemplate {
  id             String               @id @default(uuid())
  organizationId String?              @default("default-tenant")
  name           String
  description    String?
  createdAt      DateTime             @default(now())
  processes      OffboardingProcess[]
  tasks          OffboardingTask[]

  @@index([organizationId])
}

model OffboardingTask {
  id             String              @id @default(uuid())
  organizationId String?             @default("default-tenant")
  templateId     String
  title          String
  description    String?
  category       String              @default("General")
  dueAfterDays   Int                 @default(1)
  isRequired     Boolean             @default(true)
  order          Int                 @default(0)
  template       OffboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([organizationId, templateId])
}

model OffboardingItem {
  id             String             @id @default(uuid())
  organizationId String?            @default("default-tenant")
  offboardingId  String
  title          String
  category       String
  dueDate        DateTime?
  completedAt    DateTime?
  completedBy    String?
  notes          String?
  isRequired     Boolean            @default(true)
  offboarding    OffboardingProcess @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([organizationId, offboardingId])
}

model BenefitPlan {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  category       String
  description    String?
  employerAmount Decimal? @default(0)
  employeeAmount Decimal? @default(0)
  taxable        Boolean  @default(false)
  payrollCode    String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status, category])
}

model EmployeeBenefitEnrollment {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  benefitPlanId  String
  startDate      DateTime
  endDate        DateTime?
  employeeAmount Decimal?  @default(0)
  employerAmount Decimal?  @default(0)
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, employeeId, status])
  @@index([benefitPlanId])
}

model Shift {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  startTime       String
  endTime         String
  timezone        String   @default("Africa/Accra")
  gracePeriodMins Int      @default(10)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, status])
}

model EmployeeShift {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  shiftId        String
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  assignedById   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, employeeId, effectiveFrom])
  @@index([shiftId])
}

model ShiftAttendanceRule {
  id               String   @id @default(uuid())
  organizationId   String
  shiftId          String
  lateAfterMins    Int      @default(10)
  halfDayAfterMins Int      @default(240)
  absentAfterMins  Int      @default(480)
  requiresGeoFence Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId, shiftId])
}

model TaxRule {
  id             String    @id @default(uuid())
  organizationId String
  countryCode    String
  taxType        String
  name           String
  appliesTo      String?   @default("PAYROLL")
  isActive       Boolean   @default(true)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, countryCode, taxType, isActive])
}

model TaxBracket {
  id             String   @id @default(uuid())
  organizationId String
  taxRuleId      String
  minAmount      Decimal
  maxAmount      Decimal?
  rate           Decimal
  fixedAmount    Decimal? @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, taxRuleId])
}

model SystemLog {
  id             String   @id @default(uuid())
  action         String?
  details        String?
  operatorId     String?
  operatorEmail  String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  message        String?
  organizationId String?  @default("default-tenant")
  source         String?
  type           String?

  @@index([organizationId, createdAt])
  @@index([type, createdAt])
}

model EmployeeReporting {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  employeeId     String
  managerId      String
  type           String    @default("DIRECT")
  isPrimary      Boolean   @default(false)
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  employee       User      @relation("EmployeeReportingLines", fields: [employeeId], references: [id], onDelete: Cascade)
  manager        User      @relation("ManagerReportingLines", fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([employeeId, managerId, type])
  @@index([organizationId, employeeId])
  @@index([organizationId, managerId])
}

model KpiUpdate {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  kpiItemId      String
  value          Decimal
  comment        String?
  submittedById  String?
  createdAt      DateTime @default(now())
  kpiItem        KpiItem  @relation(fields: [kpiItemId], references: [id], onDelete: Cascade)

  @@index([organizationId, kpiItemId])
  @@index([createdAt])
}

model SupportTicket {
  id             String          @id @default(uuid())
  organizationId String?         @default("default-tenant")
  subject        String
  description    String
  category       String
  priority       String          @default("NORMAL")
  status         String          @default("OPEN")
  employeeId     String
  assignedToId   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assignedTo     User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  employee       User            @relation("EmployeeTickets", fields: [employeeId], references: [id], onDelete: Cascade)
  comments       TicketComment[]

  @@index([organizationId, status])
  @@index([employeeId])
}

model TicketComment {
  id             String        @id @default(uuid())
  organizationId String?       @default("default-tenant")
  ticketId       String
  userId         String
  content        String
  attachmentUrl  String?
  createdAt      DateTime      @default(now())
  ticket         SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, ticketId])
}
