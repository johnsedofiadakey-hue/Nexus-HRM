}


model TaxRule {
  id             String    @id @default(uuid())
  organizationId String
  countryCode    String
  taxType        String
  name           String
  appliesTo      String?   @default("PAYROLL")
  isActive       Boolean   @default(true)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, countryCode, taxType, isActive])
}

model TaxBracket {
  id             String   @id @default(uuid())
  organizationId String
  taxRuleId      String
  minAmount      Decimal
  maxAmount      Decimal?
  rate           Decimal
  fixedAmount    Decimal? @default(0)
