// Enums converted to strings for SQLite compatibility

// --- MISSING MODELS (MINIMAL STUBS) ---
model KpiSheet {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  month          Int
  year           Int
  lockedAt       DateTime?
  title          String
  employee       User?     @relation("EmployeeKPIs", fields: [employeeId], references: [id])
  employeeId     String?
  reviewer       User?     @relation("ReviewerKPIs", fields: [reviewerId], references: [id])
  reviewerId     String?
  totalScore     Float?
  status         String?   @default("DRAFT")
  isLocked       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  items          KpiItem[]

  @@index([organizationId, employeeId])
  @@index([organizationId, reviewerId])
  @@index([organizationId, month, year])
}

model KpiItem {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  targetValue    Float
  weight         Float     @default(1.0)
  actualValue    Float
  sheet          KpiSheet  @relation(fields: [sheetId], references: [id])
  sheetId        String
  name           String
  category       String    @default("General")
  description    String    @default("")
  score          Float?
  createdAt      DateTime  @default(now())
  lastEntryDate  DateTime?

  @@index([organizationId, sheetId])
}

// --- ASSET MODULE ---
// Asset Enums converted to strings

model Asset {
  id                String            @id @default(uuid())
  organizationId    String?           @default("default-tenant")
  name              String
  description       String?
  isCompanyProperty Boolean           @default(true)
  serialNumber      String            @unique
  make              String?
  model             String?
  type              String
  status            String            @default("AVAILABLE")
  purchaseDate      DateTime?
  warrantyExpiry    DateTime?
  assignments       AssetAssignment[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  action         String?
  entity         String?
  entityId       String?
  details        String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}

model EmployeeHistory {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employee       User?    @relation("EmployeeHistory", fields: [employeeId], references: [id])
  employeeId     String?
  createdBy      User?    @relation("CreatedHistory", fields: [createdById], references: [id])
  createdById    String?
  title          String?
  description    String?
  change         String?
  type           String?
  severity       String?
  status         String?  @default("OPEN")
  loggedById     String?
  loggedBy       User?    @relation("LoggedByHistory", fields: [loggedById], references: [id])
  createdAt      DateTime @default(now())

  @@index([organizationId, employeeId])
}

model AssetAssignment {
  id                String    @id @default(uuid())
  organizationId    String?   @default("default-tenant")
  returnedAt        DateTime?
  details           String?
  status            String?   @default("OPEN")
  conditionOnAssign String?
  conditionOnReturn String?
  loggedById        String?
  loggedBy          User?     @relation("LoggedByAssignments", fields: [loggedById], references: [id])
  user              User?     @relation("UserAssignments", fields: [userId], references: [id])
  userId            String?
  asset             Asset?    @relation(fields: [assetId], references: [id])
  assetId           String?
  assignedAt        DateTime  @default(now())

  @@index([organizationId, userId])
}

// This is your Database Schema. 
// It defines the flow from User Hierarchy to Performance Data.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- ENUMS (Strict Categories) ---
// Role and status enums converted to strings

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  fullName            String
  role                String               @default("STAFF") // DEV, MD, DIRECTOR, MANAGER, MID_MANAGER, STAFF, CASUAL
  employeeCode        String?
  status              String               @default("ACTIVE")
  position            String?
  departmentId        Int?
  departmentObj       Department?          @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  jobTitle            String
  joinDate            DateTime?
  employmentType      String?
  dob                 DateTime?
  gender              String?
  nationalId          String?
  contactNumber       String?
  address             String?
  profilePhoto        String?
  nextOfKinName       String?
  nextOfKinRelation   String?
  nextOfKinContact    String?
  avatarUrl           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  salary              Decimal?
  currency            String               @default("GHS")
  bankName            String?
  bankAccountNumber   String?
  bankBranch          String?
  ssnitNumber         String?
  bankAccountEnc      String?
  ghanaCardEnc        String?
  ssnitEnc            String?
  salaryEnc           String?
  nationalIdDocUrl    String?
  leaveBalance        Float                @default(0)
  leaveAllowance      Float                @default(24)
  leaveAccruedAt      DateTime?
  supervisorId        String?
  supervisor          User?                @relation("Hierarchy", fields: [supervisorId], references: [id])
  subordinates        User[]               @relation("Hierarchy")
  kpiSheets           KpiSheet[]           @relation("EmployeeKPIs")
  kpiReviews          KpiSheet[]           @relation("ReviewerKPIs")
  leaves              LeaveRequest[]       @relation("EmployeeLeaves")
  reliefRequests      LeaveRequest[]       @relation("RelieverLeaves")
  auditLogs           AuditLog[]
  myAppraisals        Appraisal[]          @relation("MyAppraisals")
  managerAppraisals   Appraisal[]          @relation("ManagerAppraisals")
  historyLogs         EmployeeHistory[]    @relation("EmployeeHistory")
  documents           EmployeeDocument[]   @relation("EmployeeDocuments")
  queriesReceived     EmployeeQuery[]      @relation("QueryRecipient")
  queriesIssued       EmployeeQuery[]      @relation("QueryIssuer")
  createdHistory      EmployeeHistory[]    @relation("CreatedHistory")
  userAssignments     AssetAssignment[]    @relation("UserAssignments")
  loggedByAssignments AssetAssignment[]    @relation("LoggedByAssignments")
  loggedByHistory     EmployeeHistory[]    @relation("LoggedByHistory")
  managesDepartment   Department[]         @relation("DepartmentManager")
  notifications       Notification[]       @relation("UserNotifications")
  payrollItems        PayrollItem[]        @relation("EmployeePayroll")
  onboardingSessions  OnboardingSession[]  @relation("EmployeeOnboarding")
  trainingEnrollments TrainingEnrollment[] @relation("EmployeeTraining")
  resetTokens         PasswordResetToken[] @relation("UserResetTokens")
  subscriptions       Subscription[]       @relation("ClientSubscription")
  saasSubscriptions   SaasSubscription[]   @relation("ClientSaasSubscription")

  // New Module Relations
  loans               Loan[]                @relation("EmployeeLoans")
  approvedLoans       Loan[]                @relation("ApprovedLoans")
  expenses            ExpenseClaim[]        @relation("EmployeeExpenses")
  approvedExpenses    ExpenseClaim[]        @relation("ApprovedExpenses")
  attendanceLogs      AttendanceLog[]       @relation("EmployeeAttendance")
  compensationHistory CompensationHistory[] @relation("EmployeeCompensation")
  announcements       Announcement[]        @relation("CreatedAnnouncements")

  // Archival (Soft Delete)
  isArchived   Boolean        @default(false)
  archivedDate DateTime?
  RefreshToken RefreshToken[]

  // Multi-Tenancy
  organizationId String?      @default("default-tenant")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([role, status])
  @@index([departmentId, isArchived, status])
  @@index([supervisorId])
  @@index([organizationId])
  @@unique([employeeCode, organizationId])
}

// ─── COMPENSATION HISTORY ──────────────────────────────────────────────────
model CompensationHistory {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String
  employee       User     @relation("EmployeeCompensation", fields: [employeeId], references: [id], onDelete: Cascade)
  type           String // INCREMENT, DECREMENT, ADJUSTMENT
  previousSalary Decimal
  newSalary      Decimal
  currency       String   @default("GHS")
  reason         String?
  effectiveDate  DateTime
  authorizedById String?
  createdAt      DateTime @default(now())

  @@index([organizationId, employeeId])
}

// ─── PASSWORD RESET TOKENS ─────────────────────────────────────────────────
model PasswordResetToken {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  userId         String
  user           User      @relation("UserResetTokens", fields: [userId], references: [id], onDelete: Cascade)
  token          String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([organizationId, userId])
}

// ─── DOCUMENTS & QUERIES ───────────────────────────────────────────────────
model EmployeeDocument {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String
  employee       User     @relation("EmployeeDocuments", fields: [employeeId], references: [id], onDelete: Cascade)
  title          String
  category       String // e.g., 'Certification', 'Contract', 'ID', 'Other'
  fileUrl        String // Data URL (base64) or external URL
  uploadedAt     DateTime @default(now())

  @@index([organizationId, employeeId])
}

model EmployeeQuery {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String
  employee       User     @relation("QueryRecipient", fields: [employeeId], references: [id])
  issuedById     String
  issuedBy       User     @relation("QueryIssuer", fields: [issuedById], references: [id])
  subject        String
  description    String
  status         String   @default("OPEN") // OPEN, RESPONDED, RESOLVED
  resolution     String? // Manager notes on how it was finalized
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, employeeId])
}

model Department {
  id             Int      @id @default(autoincrement())
  organizationId String?  @default("default-tenant")
  name           String   @unique
  managerId      String?
  manager        User?    @relation("DepartmentManager", fields: [managerId], references: [id])
  employees      User[]   @relation("DepartmentEmployees")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model LeaveRequest {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  employeeId     String
  employee       User     @relation("EmployeeLeaves", fields: [employeeId], references: [id])

  startDate DateTime
  endDate   DateTime
  leaveDays Float    @default(0)
  reason    String

  // The "Handover Protocol"
  relieverId String?
  reliever   User?   @relation("RelieverLeaves", fields: [relieverId], references: [id])

  status         String  @default("PENDING_RELIEVER")
  managerComment String?

  createdAt DateTime @default(now())

  @@index([organizationId, employeeId, status])
}

// --- UNIVERSAL CYCLE ENGINE ---
model Cycle {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  name           String // e.g., "Q1 2024", "Annual 2024"
  type           String
  startDate      DateTime
  endDate        DateTime
  status         String   @default("DRAFT")

  // Relations
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appraisals Appraisal[]

  @@index([organizationId])
}

model ReviewCycle {
  id             String                @id @default(uuid())
  organizationId String
  title          String
  startDate      DateTime
  endDate        DateTime
  status         String                @default("ACTIVE") // ACTIVE, COMPLETED, ARCHIVED
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  reviews        PerformanceReviewV2[]
}

model Announcement {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  title          String
  content        String
  createdBy      User      @relation("CreatedAnnouncements", fields: [createdById], references: [id])
  createdById    String
  targetAudience String // ALL, DEPARTMENT, MANAGERS, EXECUTIVES
  departmentId   Int?
  publishDate    DateTime  @default(now())
  expirationDate DateTime?
  priority       String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, targetAudience, expirationDate])
}

// --- APPRAISAL MODULE ---

model Competency {
  id             String @id @default(uuid())
  organizationId String? @default("default-tenant")
  name           String
  description    String
  weight         Float  @default(1.0)

  ratings AppraisalRating[]

  @@index([organizationId])
  @@index([name])
}

model Appraisal {
  id             String @id @default(uuid())
  organizationId String? @default("default-tenant")

  employeeId String
  employee   User   @relation("MyAppraisals", fields: [employeeId], references: [id])

  reviewerId String // Manager at time of creation
  reviewer   User   @relation("ManagerAppraisals", fields: [reviewerId], references: [id])

  cycleId String
  cycle   Cycle  @relation(fields: [cycleId], references: [id])

  status     String @default("PENDING_SELF")
  finalScore Float?

  ratings AppraisalRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, cycleId]) // One appraisal per cycle per employee
  @@index([organizationId])
  @@index([organizationId, reviewerId])
  @@index([cycleId])
}

model AppraisalRating {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  appraisalId    String
  appraisal      Appraisal @relation(fields: [appraisalId], references: [id])

  competencyId String
  competency   Competency @relation(fields: [competencyId], references: [id])

  selfScore    Float?
  managerScore Float?

  selfComment    String?
  managerComment String?

  updatedAt DateTime @updatedAt

  @@unique([appraisalId, competencyId])
  @@index([organizationId])
}

// --- SAAS / WHITE LABEL ENGINE ---
// ─── SaaS MULTI-TENANCY ────────────────────────────────────────────────────
model Organization {
  id             String   @id @default(uuid())
  name           String
  logoUrl        String?
  email          String?
  phone          String?
  address        String?
  city           String?
  country        String?
  currency       String   @default("GHS")
  
  // Subscription & Billing
  subscriptionPlan   String   @default("FREE") // FREE, PRO, ENTERPRISE, PREMIUM
  subscriptionAmount Decimal  @default(0)
  billingStatus      String   @default("ACTIVE") // ACTIVE, OVERDUE, SUSPENDED
  isSuspended        Boolean  @default(false)
  nextBillingDate    DateTime?
  
  // Branding (Moved from SystemSettings)
  primaryColor   String   @default("#4F46E5")
  secondaryColor String   @default("#1E293B")
  accentColor    String   @default("#F59E0B")
  textColor      String   @default("#FFFFFF")
  sidebarColor   String   @default("#080c16")
  subtitle       String   @default("HRM OS")
  themePreset    String   @default("nexus-dark")
  lightMode      Boolean  @default(false)

  // Relations
  users          User[]
  settings       SystemSettings?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SystemSettings {
  id             String  @id @default(uuid())
  organizationId String? @unique
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Security / Kill Switch
  isMaintenanceMode Boolean @default(false)
  securityLockdown  Boolean @default(false)

  // Email Config
  smtpHost String?
  smtpPort Int?
  smtpUser String?
  smtpPass String?
  smtpFrom String?

  // Paystack Config
  paystackPublicKey String?
  paystackSecretKey String?
  monthlyPriceGHS   Decimal?
  annualPriceGHS    Decimal?
  trialDays         Int      @default(14)

  // Login Customization
  loginNotice   String?
  loginSubtitle String?
  loginBullets  String?

  updatedAt DateTime @updatedAt
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────────────
model Notification {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  userId         String
  user           User     @relation("UserNotifications", fields: [userId], references: [id])
  title          String
  message        String
  type           String   @default("INFO") // INFO | WARNING | SUCCESS | ERROR
  link           String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([organizationId, userId, isRead])
}

// ─── PAYROLL ───────────────────────────────────────────────────────────────
// Payroll Status enums converted to strings

model PayrollRun {
  id             String        @id @default(uuid())
  organizationId String?       @default("default-tenant")
  period         String // e.g. "2025-03"
  month          Int
  year           Int
  status         String        @default("DRAFT")
  totalGross     Decimal       @default(0)
  totalNet       Decimal       @default(0)
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          PayrollItem[]

  @@index([organizationId, year, month, status])
  @@index([period, status])
}

model PayrollItem {
  id              String     @id @default(uuid())
  organizationId  String?    @default("default-tenant")
  runId           String
  run             PayrollRun @relation(fields: [runId], references: [id])
  employeeId      String
  employee        User       @relation("EmployeePayroll", fields: [employeeId], references: [id])
  baseSalary      Decimal
  currency        String     @default("GHS")
  // Additions
  overtime        Decimal    @default(0)
  bonus           Decimal    @default(0)
  allowances      Decimal    @default(0)
  // Deductions
  tax             Decimal    @default(0)
  ssnit           Decimal    @default(0) // Social security
  otherDeductions Decimal    @default(0)
  // Totals
  grossPay        Decimal
  netPay          Decimal
  notes           String?
  createdAt       DateTime   @default(now())

  @@unique([runId, employeeId])
  @@index([organizationId])
}

// ─── ONBOARDING ────────────────────────────────────────────────────────────
model OnboardingTemplate {
  id             String              @id @default(uuid())
  organizationId String?             @default("default-tenant")
  name           String
  description    String?
  isDefault      Boolean             @default(false)
  tasks          OnboardingTask[]
  sessions       OnboardingSession[]
  createdAt      DateTime            @default(now())

  @@index([organizationId])
}

model OnboardingTask {
  id             String             @id @default(uuid())
  organizationId String?            @default("default-tenant")
  templateId     String
  template       OnboardingTemplate @relation(fields: [templateId], references: [id])
  title          String
  description    String?
  category       String             @default("General") // HR | IT | Admin | Manager
  dueAfterDays   Int                @default(1)
  isRequired     Boolean            @default(true)
  order          Int                @default(0)

  @@index([organizationId, templateId])
}

model OnboardingSession {
  id             String             @id @default(uuid())
  organizationId String?            @default("default-tenant")
  employeeId     String
  employee       User               @relation("EmployeeOnboarding", fields: [employeeId], references: [id])
  templateId     String
  template       OnboardingTemplate @relation(fields: [templateId], references: [id])
  startDate      DateTime           @default(now())
  completedAt    DateTime?
  progress       Int                @default(0) // 0-100
  items          OnboardingItem[]
  createdAt      DateTime           @default(now())

  @@index([organizationId, employeeId])
}

model OnboardingItem {
  id             String            @id @default(uuid())
  organizationId String?           @default("default-tenant")
  sessionId      String
  session        OnboardingSession @relation(fields: [sessionId], references: [id])
  taskId         String
  title          String
  category       String
  dueDate        DateTime?
  completedAt    DateTime?
  completedBy    String?
  notes          String?
  isRequired     Boolean           @default(true)

  @@index([organizationId, sessionId])
}

// ─── TRAINING ──────────────────────────────────────────────────────────────
// Training Status enums converted to strings

model TrainingProgram {
  id             String               @id @default(uuid())
  organizationId String?              @default("default-tenant")
  title          String
  description    String?
  provider       String?
  startDate      DateTime?
  endDate        DateTime?
  durationHours  Int?
  cost           Decimal?
  maxSeats       Int?
  status         String               @default("PLANNED")
  createdById    String?
  enrollments    TrainingEnrollment[]
  createdAt      DateTime             @default(now())

  @@index([organizationId, status])
  @@index([organizationId])
}

model TrainingEnrollment {
  id             String          @id @default(uuid())
  organizationId String?         @default("default-tenant")
  programId      String
  program        TrainingProgram @relation(fields: [programId], references: [id])
  employeeId     String
  employee       User            @relation("EmployeeTraining", fields: [employeeId], references: [id])
  enrolledAt     DateTime        @default(now())
  completedAt    DateTime?
  score          Float?
  certificate    String?
  status         String          @default("ENROLLED") // ENROLLED | COMPLETED | DROPPED

  @@unique([programId, employeeId])
  @@index([organizationId, employeeId])
}

// ─── HOLIDAYS ──────────────────────────────────────────────────────────────
model PublicHoliday {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  name           String
  date           DateTime
  country        String   @default("GH")
  isRecurring    Boolean  @default(true) // repeats yearly
  year           Int? // null = recurring every year
  createdAt      DateTime @default(now())

  @@index([organizationId, country, date])
}

// ─── THEMES ────────────────────────────────────────────────────────────────
// Theme presets stored in SystemSettings via JSON fields (no separate model needed)
// We'll extend SystemSettings to have a themePreset field

// ─── SUBSCRIPTION / BILLING ────────────────────────────────────────────────
model Subscription {
  id                 String    @id @default(uuid())
  organizationId     String?   @default("default-tenant")
  clientId           String // MD user ID of the client org
  client             User      @relation("ClientSubscription", fields: [clientId], references: [id])
  plan               String    @default("MONTHLY") // MONTHLY | ANNUALLY
  priceGHS           Decimal
  status             String    @default("TRIAL") // TRIAL | ACTIVE | EXPIRED | CANCELLED
  orgName            String? // Client organisation name
  contactEmail       String? // Billing contact email
  paystackRef        String? // Paystack transaction reference
  paystackSubCode    String? // Paystack subscription code for recurring
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([organizationId])
}

// ─── LOANS & ADVANCES ──────────────────────────────────────────────────────
model Loan {
  id                String  @id @default(uuid())
  organizationId    String? @default("default-tenant")
  employeeId        String
  employee          User    @relation("EmployeeLoans", fields: [employeeId], references: [id], onDelete: Cascade)
  type              String  @default("ADVANCE") // ADVANCE, LOAN
  principalAmount   Decimal
  interestRate      Decimal @default(0)
  totalRepayment    Decimal
  installmentAmount Decimal
  monthsDuration    Int
  purpose           String?
  status            String  @default("PENDING") // PENDING, APPROVED, REJECTED, ACTIVE, PAID_OFF

  requestedAt  DateTime  @default(now())
  approvedAt   DateTime?
  approvedById String?
  approver     User?     @relation("ApprovedLoans", fields: [approvedById], references: [id])

  installments LoanInstallment[]

  @@index([organizationId, employeeId])
}

model LoanInstallment {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  loanId         String
  loan           Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount         Decimal
  deductedRunId  String? // References PayrollRun if inducted directly
  month          Int
  year           Int
  status         String    @default("PENDING") // PENDING, PAID, SKIPPED
  paidAt         DateTime?

  @@index([organizationId, loanId])
}

// ─── EXPENSES & CLAIMS ─────────────────────────────────────────────────────
model ExpenseClaim {
  id             String  @id @default(uuid())
  organizationId String? @default("default-tenant")
  employeeId     String
  employee       User    @relation("EmployeeExpenses", fields: [employeeId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  amount         Decimal
  currency       String  @default("GHS")
  category       String // TRAVEL, SUPPLIES, MEALS, OTHER
  receiptUrl     String?
  status         String  @default("PENDING") // PENDING, APPROVED, REJECTED, PAID

  submittedAt  DateTime  @default(now())
  approvedAt   DateTime?
  approvedById String?
  approver     User?     @relation("ApprovedExpenses", fields: [approvedById], references: [id])

  paidInRunId String? // References PayrollRun if paid via payroll

  @@index([organizationId, employeeId, status])
}

// ─── ATTENDANCE ────────────────────────────────────────────────────────────
model AttendanceLog {
  id             String    @id @default(uuid())
  organizationId String?   @default("default-tenant")
  employeeId     String
  employee       User      @relation("EmployeeAttendance", fields: [employeeId], references: [id], onDelete: Cascade)
  date           DateTime // Normalized to midnight
  clockIn        DateTime?
  clockOut       DateTime?
  status         String    @default("PRESENT") // PRESENT, LATE, ABSENT, HALF_DAY
  notes          String?

  // Geolocation metadata (Optional future proofing)
  locationIn  String?
  locationOut String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([organizationId, date, status])
  @@index([employeeId, clockIn, clockOut])
}

// ─── SAAS BILLING (Paystack) ───────────────────────────────────────────────
model SaasSubscription {
  id              String    @id @default(uuid())
  organizationId  String?   @default("default-tenant")
  clientId        String // Hardcoded or linked to User if multi-tenant
  client          User      @relation("ClientSaasSubscription", fields: [clientId], references: [id])
  plan            String    @default("MONTHLY") // MONTHLY, ANNUALLY
  status          String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  amount          Decimal   @default(50.00) // Base subscription fee
  nextBillingDate DateTime
  lastPaymentDate DateTime?
  paystackRef     String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
}

// ─── SYSTEM BACKUP LOGS ────────────────────────────────────────────────────
model BackupLog {
  id             String   @id @default(uuid())
  organizationId String?  @default("default-tenant")
  filename       String
  sizeBytes      Int
  status         String   @default("SUCCESS") // SUCCESS, FAILED
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

// ─── ENTERPRISE V4 MODELS ────────────────────────────────────────────────

model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  tokenHash      String    @unique
  ipAddress      String?
  userAgent      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([expiresAt])
}

model LoginSecurityEvent {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  ipAddress      String?
  userAgent      String?
  success        Boolean  @default(false)
  reason         String?
  createdAt      DateTime @default(now())

  @@index([organizationId, email, createdAt])
  @@index([ipAddress, createdAt])
}

model DepartmentKPI {
  id                String   @id @default(uuid())
  organizationId    String
  departmentId      Int
  title             String
  description       String?
  metricType        String
  targetValue       Float
  measurementPeriod String
  assignedById      String
  assignedToId      String?
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId, departmentId, measurementPeriod])
  @@index([organizationId, assignedToId])
  @@index([assignedById])
}

model TeamTarget {
  id                String   @id @default(uuid())
  organizationId    String
  departmentKpiId   String
  managerId         String
  teamName          String?
  title             String
  description       String?
  metricType        String
  targetValue       Float
  measurementPeriod String
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId, departmentKpiId])
  @@index([organizationId, managerId, measurementPeriod])
}

model EmployeeTarget {
  id                String   @id @default(uuid())
  organizationId    String
  teamTargetId      String
  employeeId        String
  title             String
  description       String?
  metricType        String
  targetValue       Float
  measurementPeriod String
  assignedById      String
  assignedToId      String
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId, employeeId, measurementPeriod])
  @@index([organizationId, teamTargetId])
  @@index([assignedById])
}

model PerformanceReviewV2 {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  managerId      String?
  directorId     String?
  cycle          String
  selfReview     String?
  managerReview  String?
  directorReview String?
  selfScore      Float?
  managerScore   Float?
  directorScore  Float?
  finalScore     Float?
  cycleId        String
  cycleObj       ReviewCycle @relation(fields: [cycleId], references: [id])
  status         String      @default("DRAFT")
  submittedAt    DateTime?
  validatedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([organizationId, employeeId, cycleId])
  @@index([organizationId, status])
  @@index([managerId, directorId])
}

model PerformanceScore {
  id                  String   @id @default(uuid())
  organizationId      String
  performanceReviewId String
  kpiTitle            String
  metricType          String
  targetValue         Float?
  achievedValue       Float?
  weightedScore       Float?
  notes               String?
  createdAt           DateTime @default(now())

  @@index([organizationId, performanceReviewId])
}

model JobPosition {
  id             String    @id @default(uuid())
  organizationId String
  title          String
  departmentId   Int?
  description    String?
  location       String?
  employmentType String?
  status         String    @default("OPEN")
  openedById     String?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, status, createdAt])
}

model Candidate {
  id             String   @id @default(uuid())
  organizationId String
  jobPositionId  String
  fullName       String
  email          String?
  phone          String?
  resumeUrl      String?
  source         String?
  status         String   @default("APPLIED")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, jobPositionId, status])
  @@index([email, phone])
}

model InterviewStage {
  id             String    @id @default(uuid())
  organizationId String
  candidateId    String
  stage          String
  scheduledAt    DateTime?
  interviewerId  String?
  outcome        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, candidateId, stage])
}

model InterviewFeedback {
  id               String   @id @default(uuid())
  organizationId   String
  candidateId      String
  interviewStageId String?
  reviewerId       String
  rating           Float?
  feedback         String?
  recommendation   String?
  createdAt        DateTime @default(now())

  @@index([organizationId, candidateId])
  @@index([organizationId, reviewerId])
  @@index([interviewStageId])
}

model OfferLetter {
  id             String    @id @default(uuid())
  organizationId String
  candidateId    String
